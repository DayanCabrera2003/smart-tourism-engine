# Configuración del Smart Tourism Engine

# URL de la base de datos vectorial Qdrant (en Docker: http://qdrant:6333, local: http://localhost:6333)
QDRANT_URL=http://localhost:6333

# API Key para el LLM  - Requerido para RAG
LLM_API_KEY=tu_api_key_aqui

# Proveedor del LLM: "gemini" (por defecto) o "ollama" para uso offline
LLM_PROVIDER=gemini

# URL de Ollama y modelo (solo necesario si LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# API Key para OpenTripMap - Requerido para la ingesta desde OpenTripMap
OPENTRIPMAP_API_KEY=tu_api_key_opentripmap_aqui

# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Directorio base para los datos (data/processed, data/raw, etc.)
DATA_DIR=data
